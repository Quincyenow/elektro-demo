---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { business } from '../data/business.ts';
---

<Layout
  title="Elektro Stebel – Elektromeisterbetrieb in Hannover"
  description="Elektroinstallation, Smart Home, Photovoltaik und Wallbox-Montage in Hannover und Umgebung. 10+ Jahre Erfahrung, 24h Notdienst, kostenlose Beratung."
  canonicalPath="/"
>

<style>
  nav{
    position:fixed;top:0;left:0;right:0;z-index:100;
    display:flex;align-items:center;justify-content:space-between;
    padding:1.2rem 2rem;
    background:rgba(13,13,13,0.92);
    backdrop-filter:blur(12px);
    border-bottom:1px solid rgba(255,255,255,0.06);
  }
  .nav-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;letter-spacing:-0.02em}
  .nav-logo span{color:var(--yellow)}
  .nav-links{display:flex;gap:2rem}
  .nav-links a{font-size:0.85rem;color:var(--text-muted);text-decoration:none;transition:color 0.2s}
  .nav-links a:hover{color:var(--white)}
  .nav-cta{
    background:var(--yellow);color:var(--black);
    padding:0.5rem 1.2rem;border-radius:6px;
    font-size:0.85rem;font-weight:600;text-decoration:none;
    transition:background 0.2s;
  }
  .nav-cta:hover{background:var(--yellow-dark)}

  .hero{
    min-height:100vh;
    display:grid;grid-template-columns:1fr 1fr;
    align-items:center;
    padding:8rem 2rem 4rem;
    gap:4rem;
    max-width:1200px;margin:0 auto;
  }
  .hero-eyebrow{
    display:inline-flex;align-items:center;gap:0.5rem;
    font-size:0.75rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;
    color:var(--yellow);margin-bottom:1.5rem;
  }
  .hero-eyebrow::before{content:'';width:24px;height:2px;background:var(--yellow)}
  .hero h1{
    font-family:'Syne',sans-serif;font-weight:800;
    font-size:clamp(2.5rem,5vw,4rem);
    line-height:1.05;letter-spacing:-0.03em;
    margin-bottom:1.5rem;
    overflow-wrap:break-word;
  }
  .hero h1 em{color:var(--yellow);font-style:normal}
  .hero-sub{color:var(--text-muted);font-size:1rem;max-width:420px;margin-bottom:2rem;line-height:1.7}
  .hero-actions{display:flex;gap:1rem;flex-wrap:wrap}

  .btn-primary{
    background:var(--yellow);color:var(--black);
    padding:0.85rem 1.8rem;border-radius:8px;
    font-weight:600;font-size:0.9rem;text-decoration:none;
    transition:background 0.2s,transform 0.15s;display:inline-block;
  }
  .btn-primary:hover{background:var(--yellow-dark);transform:translateY(-1px)}
  .btn-ghost{
    border:1px solid rgba(255,255,255,0.15);
    padding:0.85rem 1.8rem;border-radius:8px;
    font-size:0.9rem;color:var(--white);text-decoration:none;
    transition:border-color 0.2s,background 0.2s;display:inline-block;
  }
  .btn-ghost:hover{border-color:rgba(255,255,255,0.4);background:rgba(255,255,255,0.04)}

  .hero-visual{
    position:relative;border-radius:16px;overflow:hidden;
    aspect-ratio:4/3;background:var(--gray);
  }
  .hero-visual img{width:100%;height:100%;object-fit:cover;opacity:0.85}
  .hero-badge{
    position:absolute;bottom:1.5rem;left:1.5rem;
    background:rgba(13,13,13,0.88);
    backdrop-filter:blur(8px);
    border:1px solid rgba(255,255,255,0.1);
    border-radius:10px;padding:0.75rem 1rem;
    display:flex;gap:1.5rem;
  }
  .badge-stat{text-align:center}
  .badge-stat-num{font-family:'Syne',sans-serif;font-weight:800;font-size:1.2rem;color:var(--yellow)}
  .badge-stat-label{font-size:0.7rem;color:var(--text-muted);letter-spacing:0.04em}

  .ticker-wrap{background:var(--yellow);overflow:hidden;padding:0.7rem 0}
  .ticker{display:flex;gap:3rem;white-space:nowrap;animation:tick 22s linear infinite}
  @keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  .ticker-item{font-size:0.8rem;font-weight:600;color:var(--black);letter-spacing:0.04em;text-transform:uppercase}
  .ticker-dot{color:rgba(0,0,0,0.3);margin:0 0.5rem}

  .section{padding:5rem 2rem;max-width:1200px;margin:0 auto}
  .section-full{padding:5rem 2rem;background:var(--gray-mid)}
  .section-full-inner{max-width:1200px;margin:0 auto}
  .section-eye{font-size:0.72rem;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;color:var(--yellow);margin-bottom:0.75rem}
  .section-title{
    font-family:'Syne',sans-serif;font-weight:800;
    font-size:clamp(1.8rem,3vw,2.6rem);
    letter-spacing:-0.02em;margin-bottom:1rem;
  }
  .section-sub{color:var(--text-muted);max-width:480px;line-height:1.7;margin-bottom:3rem}

  .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
  .about-text p{color:var(--text-muted);line-height:1.8;margin-bottom:1rem}
  .about-stats{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
  .stat-card{
    background:var(--gray);border:1px solid rgba(255,255,255,0.06);
    border-radius:12px;padding:1.5rem;
  }
  .stat-num{font-family:'Syne',sans-serif;font-weight:800;font-size:2rem;color:var(--yellow)}
  .stat-label{font-size:0.8rem;color:var(--text-muted);margin-top:0.2rem}

  .services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem}
  .service-card{
    background:var(--gray);border:1px solid rgba(255,255,255,0.06);
    border-radius:12px;padding:1.5rem;
    transition:border-color 0.2s,transform 0.2s;
  }
  .service-card:hover{border-color:var(--yellow);transform:translateY(-3px)}
  .service-icon{font-size:1.5rem;margin-bottom:0.75rem}
  .service-name{font-weight:600;font-size:0.95rem}
  .service-desc{font-size:0.82rem;color:var(--text-muted);margin-top:0.4rem;line-height:1.5}

  .process-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}
  .step{background:var(--gray);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:1.5rem}
  .step-num{
    width:40px;height:40px;border-radius:50%;
    background:var(--yellow);color:var(--black);
    display:flex;align-items:center;justify-content:center;
    font-family:'Syne',sans-serif;font-weight:800;font-size:0.9rem;
    margin-bottom:1rem;
  }
  .step-title{font-weight:600;margin-bottom:0.4rem}
  .step-desc{font-size:0.82rem;color:var(--text-muted);line-height:1.5}

  .reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}
  .review-card{
    background:var(--gray);border:1px solid rgba(255,255,255,0.06);
    border-radius:12px;padding:1.5rem;
  }
  .review-stars{color:var(--yellow);font-size:0.9rem;margin-bottom:1rem}
  .review-text{font-size:0.88rem;color:var(--text-muted);line-height:1.7;margin-bottom:1rem;font-style:italic}
  .review-author{font-size:0.82rem;font-weight:600}

  .contact-wrap{
    background:var(--gray);border:1px solid rgba(255,255,255,0.06);
    border-radius:16px;padding:3rem;
    display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;
  }
  .contact-info p{color:var(--text-muted);margin-bottom:1rem;font-size:0.9rem;line-height:1.7}
  .contact-detail{display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem}
  .contact-detail-icon{
    width:36px;height:36px;border-radius:8px;
    background:rgba(245,200,66,0.12);
    display:flex;align-items:center;justify-content:center;
    font-size:1rem;flex-shrink:0;
  }
  .contact-detail-text{font-size:0.88rem;color:var(--text-muted)}
  .contact-detail-text strong{color:var(--white);display:block;font-size:0.92rem}
  .contact-quick{display:flex;gap:0.75rem;margin-top:1.5rem;flex-wrap:wrap}
  .contact-quick .btn-ghost{flex:1;text-align:center}

  footer{
    border-top:1px solid rgba(255,255,255,0.06);
    padding:2rem;
    display:flex;justify-content:space-between;align-items:center;
    max-width:1200px;margin:0 auto;
  }
  .footer-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:1rem}
  .footer-logo span{color:var(--yellow)}
  .footer-copy{font-size:0.8rem;color:var(--text-muted)}
  .footer-links{display:flex;gap:1.5rem}
  .footer-links a{font-size:0.8rem;color:var(--text-muted);text-decoration:none;transition:color 0.2s}
  .footer-links a:hover{color:var(--white)}

  @media(max-width:768px){
    .hero{grid-template-columns:1fr;padding-top:6rem}
    .hero-visual{display:none}
    .about-grid,.contact-wrap{grid-template-columns:1fr}
    .process-steps{grid-template-columns:1fr 1fr}
    .reviews-grid{grid-template-columns:1fr}
    nav .nav-links{display:none}
    footer{flex-direction:column;gap:1rem;text-align:center}
  }
</style>

<nav>
  <div class="nav-logo">⚡ Elektro <span>Stebel</span></div>
  <div class="nav-links">
    <a href="#leistungen">Leistungen</a>
    <a href="#prozess">Ablauf</a>
    <a href="#bewertungen">Bewertungen</a>
    <a href="#kontakt">Kontakt</a>
  </div>
  <a href="#kontakt" class="nav-cta">Termin anfragen</a>
</nav>

<div class="hero">
  <div class="hero-content">
    <div class="hero-eyebrow">Elektromeisterbetrieb Hannover</div>
    <h1>Elektrotechnik,<br>die <em>wirklich</em><br>funktioniert.</h1>
    <p class="hero-sub">Schnell, sauber und zuverlässig. Von der klassischen Installation bis zum Smart Home – in Hannover und Umgebung.</p>
    <div class="hero-actions">
      <a href="#kontakt" class="btn-primary">Jetzt Termin vereinbaren</a>
      <a href="#leistungen" class="btn-ghost">Leistungen ansehen</a>
    </div>
  </div>
  <div class="hero-visual">
    <img src="/stebel.jpg" alt="Elektro Stebel Hannover" />
    <div class="hero-badge">
      <div class="badge-stat">
        <div class="badge-stat-num">10+</div>
        <div class="badge-stat-label">Jahre Erfahrung</div>
      </div>
      <div class="badge-stat">
        <div class="badge-stat-num">500+</div>
        <div class="badge-stat-label">Projekte</div>
      </div>
      <div class="badge-stat">
        <div class="badge-stat-num">24h</div>
        <div class="badge-stat-label">Erreichbar</div>
      </div>
    </div>
  </div>
</div>

<div class="ticker-wrap">
  <div class="ticker">
    <span class="ticker-item">24h erreichbar <span class="ticker-dot">•</span></span>
    <span class="ticker-item">{business.phone} <span class="ticker-dot">•</span></span>
    <span class="ticker-item">Hannover & Umgebung <span class="ticker-dot">•</span></span>
    <span class="ticker-item">{business.email} <span class="ticker-dot">•</span></span>
    <span class="ticker-item">Kostenlose Beratung <span class="ticker-dot">•</span></span>
    <span class="ticker-item">24h erreichbar <span class="ticker-dot">•</span></span>
    <span class="ticker-item">{business.phone} <span class="ticker-dot">•</span></span>
    <span class="ticker-item">Hannover & Umgebung <span class="ticker-dot">•</span></span>
    <span class="ticker-item">{business.email} <span class="ticker-dot">•</span></span>
    <span class="ticker-item">Kostenlose Beratung <span class="ticker-dot">•</span></span>
  </div>
</div>

<div class="section" id="about">
  <div class="about-grid">
    <div class="about-text">
      <div class="section-eye">Über uns</div>
      <h2 class="section-title">Gemeinsam denken wir Elektrotechnik <em style="color:var(--yellow);font-style:normal">neu</em></h2>
      <p>In und um Hannover sind wir als Elektromeisterbetrieb für Sie da. Von der Instandhaltung bestehender Systeme bis hin zu Neuinstallationen und Smart-Lösungen.</p>
      <p>Mit über 10 Jahren Erfahrung und mehr als 500 abgeschlossenen Projekten stehen wir für Qualität, Pünktlichkeit und faire Preise.</p>
      <br>
      <a href="#kontakt" class="btn-primary">Kostenloses Angebot anfordern →</a>
    </div>
    <div class="about-stats">
      <div class="stat-card"><div class="stat-num">10+</div><div class="stat-label">Jahre Erfahrung</div></div>
      <div class="stat-card"><div class="stat-num">500+</div><div class="stat-label">Abgeschlossene Projekte</div></div>
      <div class="stat-card"><div class="stat-num">24h</div><div class="stat-label">Erreichbar</div></div>
      <div class="stat-card"><div class="stat-num">100%</div><div class="stat-label">Kundenzufriedenheit</div></div>
    </div>
  </div>
</div>

<div class="section-full" id="leistungen">
  <div class="section-full-inner">
    <div class="section-eye">Leistungen</div>
    <h2 class="section-title">Alles aus einer Hand</h2>
    <p class="section-sub">Von der Planung bis zur Fertigstellung – wir sind Ihr kompetenter Ansprechpartner.</p>
    <div class="services-grid">
      <div class="service-card"><div class="service-icon">🔌</div><div class="service-name">Elektroinstallation</div><div class="service-desc">Neuinstallation und Modernisierung elektrischer Anlagen</div></div>
      <div class="service-card"><div class="service-icon">💡</div><div class="service-name">Beleuchtung & LED</div><div class="service-desc">Energieeffiziente Lichttechnik für jeden Bereich</div></div>
      <div class="service-card"><div class="service-icon">🏠</div><div class="service-name">Smart Home</div><div class="service-desc">Intelligente Haussteuerung und Automatisierung</div></div>
      <div class="service-card"><div class="service-icon">☀️</div><div class="service-name">Photovoltaik</div><div class="service-desc">Solaranlagen für nachhaltige Energieerzeugung</div></div>
      <div class="service-card"><div class="service-icon">🚗</div><div class="service-name">Wallbox</div><div class="service-desc">E-Ladestation für zuhause – schnell und sicher</div></div>
      <div class="service-card"><div class="service-icon">🚨</div><div class="service-name">Störungsdienst</div><div class="service-desc">24h Notfallservice bei Stromausfall & Störungen</div></div>
      <div class="service-card"><div class="service-icon">🔒</div><div class="service-name">Sicherheitstechnik</div><div class="service-desc">Alarmanlage, Kamera und Zugangskontrolle</div></div>
      <div class="service-card"><div class="service-icon">🏗️</div><div class="service-name">Gebäudeinstallation</div><div class="service-desc">Elektrik für Neubauten und Gewerbegebäude</div></div>
    </div>
  </div>
</div>

<div class="section" id="prozess">
  <div class="section-eye">Unser Ablauf</div>
  <h2 class="section-title">Schritt für Schritt zu Ihrer Lösung</h2>
  <p class="section-sub">Transparent, zuverlässig und ohne Überraschungen.</p>
  <div class="process-steps">
    <div class="step"><div class="step-num">1</div><div class="step-title">Beratung</div><div class="step-desc">Sie kontaktieren uns – wir melden uns innerhalb von 24h und besprechen Ihr Projekt.</div></div>
    <div class="step"><div class="step-num">2</div><div class="step-title">Planung</div><div class="step-desc">Wir beraten Sie ganzheitlich und erstellen ein unverbindliches Angebot.</div></div>
    <div class="step"><div class="step-num">3</div><div class="step-title">Ausführung</div><div class="step-desc">Wir setzen Ihr Projekt professionell um und halten Sie informiert.</div></div>
    <div class="step"><div class="step-num">4</div><div class="step-title">Fertigstellung</div><div class="step-desc">Abnahme, Übergabe und vollständige Dokumentation.</div></div>
  </div>
</div>

<div class="section-full" id="bewertungen">
  <div class="section-full-inner">
    <div class="section-eye">Bewertungen</div>
    <h2 class="section-title">Das sagen unsere Kunden</h2>
    <p class="section-sub">Echte Stimmen aus Hannover und Umgebung.</p>
    <div class="reviews-grid">
      <div class="review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-text">"Schnelle und professionelle Arbeit. Herr Stebel hat unsere Wallbox perfekt installiert und alles sauber erklärt. Absolute Empfehlung!"</p>
        <div class="review-author">Michael K., Hannover</div>
      </div>
      <div class="review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-text">"Bei unserem Stromausfall war das Team innerhalb von 2 Stunden vor Ort. Sehr faire Preise und top Leistung!"</p>
        <div class="review-author">Sandra M., Langenhagen</div>
      </div>
      <div class="review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-text">"Die Smart-Home Installation hat unser Zuhause komplett verändert. Sehr saubere Arbeit und freundlicher Service."</p>
        <div class="review-author">Thomas B., Garbsen</div>
      </div>
    </div>
  </div>
</div>

<div class="section" id="kontakt">
  <div class="section-eye">Kontakt</div>
  <h2 class="section-title">Jetzt Termin vereinbaren</h2>
  <p class="section-sub">24 Stunden täglich für Sie erreichbar.</p>
  <div class="contact-wrap">
    <div class="contact-info">
      <p>Wir sind Ihr zuverlässiger Partner für alle Elektroarbeiten in Hannover und Umgebung. Füllen Sie das Formular aus – wir melden uns innerhalb von 24h zurück.</p>
      <div class="contact-detail">
        <div class="contact-detail-icon">📞</div>
        <div class="contact-detail-text"><strong>{business.phone}</strong>Mo–So, 24h erreichbar</div>
      </div>
      <div class="contact-detail">
        <div class="contact-detail-icon">✉️</div>
        <div class="contact-detail-text"><strong>{business.email}</strong>Antwort innerhalb 24h</div>
      </div>
      <div class="contact-detail">
        <div class="contact-detail-icon">📍</div>
        <div class="contact-detail-text"><strong>Hannover & Umgebung</strong>Einsatzgebiet Region Hannover</div>
      </div>
      <div class="contact-quick">
        <a href={`tel:${business.phoneHref}`} class="btn-ghost">📞 Jetzt anrufen</a>
        <a href={`mailto:${business.email}`} class="btn-ghost">✉️ E-Mail schreiben</a>
      </div>
    </div>
    <div class="contact-cta">
      <ContactForm />
    </div>
  </div>
</div>

<footer>
  <div class="footer-logo">⚡ Elektro <span>Stebel</span></div>
  <div class="footer-copy">© {new Date().getFullYear()} {business.name} | {business.address.city}</div>
  <div class="footer-links">
    <a href="/impressum/">Impressum</a>
    <a href="/datenschutz/">Datenschutz</a>
  </div>
</footer>

</Layout>
